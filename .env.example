# Core
PG_LOG_LEVEL=debug
PG_API_KEY_SALT=devsalt
PG_REDIS_URL=redis://redis:6379/0

# Proxy
PG_PROXY_ADDR=:8080
PG_REQUEST_TIMEOUT=30s
PG_REDIS_TIMEOUT=8ms
PG_MAX_BUFFER_BYTES=524288
PG_DEFAULT_UPSTREAM_HOST=api.replicate.com
PG_DEFAULT_UPSTREAM_SCHEME=https

# API
PG_API_ADDR=:3001

# Optimizer / GEPA
PG_MIN_SAMPLES=20
PG_OPTIMIZE_EVERY=6h
PG_MAX_VARIANT_AGE=168h
PG_GEPA_ROLLOUT_BUDGET=50
PG_GEPA_MINIBATCH_SIZE=5
PG_GEPA_TOP_N=3
PG_GEPA_CROSSOVER=true

# Replicate (GEPA LLM)
PG_OPTIMIZER_LLM_PROVIDER=replicate
PG_REPLICATE_API_TOKEN=your_replicate_token_here
PG_REPLICATE_MODEL=openai/gpt-5.4
PG_REPLICATE_BASE_URL=https://api.replicate.com
PG_REPLICATE_REASONING_EFFORT=medium
PG_REPLICATE_VERBOSITY=medium
PG_REPLICATE_MAX_COMPLETION_TOKENS=2048
PG_REPLICATE_TEMPERATURE=0.2
PG_REPLICATE_TOP_P=1.0
PG_REPLICATE_PRESENCE_PENALTY=0.0
PG_REPLICATE_FREQUENCY_PENALTY=0.0
PG_REPLICATE_TIMEOUT=120s
PG_GEPA_OUTPUT_SIZE=3
